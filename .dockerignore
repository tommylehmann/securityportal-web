# Keep the build context small and free of host-only / sensitive files. The
# Dockerfile reinstalls dependencies from the lockfile, so node_modules must not
# leak in from the host; .env and .git must never reach the image layers.
.git
.github
node_modules
build
.svelte-kit
.env
.env.*
!.env.example
coverage
test-results
playwright-report
*-sbom.cdx.json
*-sbom.spdx.json
.eslintcache
.prettiercache
