# Base URL of the securityportal-api. Leave empty for same-origin relative
# requests to `/api/...` (proxied by the Vite dev server in development and by a
# reverse proxy in production). Set it to an absolute origin to point the web app
# at an API on a different host, e.g.:
#   PUBLIC_API_BASE_URL=https://api.example.test
PUBLIC_API_BASE_URL=
