node_modules/

# SvelteKit / build output
/build/
/.svelte-kit/
/package/

# Local environment overrides (never commit secrets)
.env
.env.*
!.env.example

# Lint / format caches
.eslintcache
.prettiercache

# Test + coverage output
/coverage/
/test-results/
/playwright-report/

