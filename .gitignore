*-sbom.cdx.json
*-sbom.spdx.json

# Editor / OS noise
.DS_Store
*.swp
vite.config.*.timestamp-*

# codegraph local index (security review F4 — may contain copied secrets)
.codegraph/

# Serena MCP local project config (tool-generated, not project source)
.serena/
